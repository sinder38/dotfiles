// -*- mode: jsonc -*-
{
  "layer": "top",
  "position": "top",
  // "height": 20,
  // "margin-top": 6,
  // "margin-left": 8,
  // "margin-right": 8,
  "spacing": 0,
  "modules-left": [
    "niri/workspaces"
  ],
  "modules-center": [
    "niri/window"
  ],
  "modules-right": [
    "pulseaudio",
    "network",
    "cpu",
    "memory",
    "backlight",
    "battery",
    "clock",
    "tray",
    "custom/notification",
    "custom/power"
  ],
  "niri/workspaces": {
    "format": "{name}"
  },
  "niri/window": {
    "max-length": 50,
    "format": "{}"
  },
  "clock": {
    "format": " {:%H:%M}",
    "format-alt": "َ°ƒ­ {:%a, %b %d}",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "cpu": {
    "format": "َ°»  {usage}%",
    "tooltip": true,
    "interval": 3
  },
  "memory": {
    "format": "َ°¾† {used:0.1f}G",
    "tooltip-format": "{used:0.1f}G used / {total:0.1f}G total"
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "َ°‹™",
      "َ°ƒ›",
      "َ°ƒ‌",
      "َ°ƒں",
      "َ°ƒ "
    ]
  },
  "battery": {
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "format-plugged": "َ°ڑ¥ {capacity}%",
    "format-icons": [
      "َ°پ؛",
      "َ°پ»",
      "َ°پ¼",
      "َ°پ½",
      "َ°پ¾",
      "َ°پ؟",
      "َ°‚€",
      "َ°‚پ",
      "َ°‚‚",
      "َ°پ¹"
    ],
    "tooltip-format": "{timeTo}"
  },
  "network": {
    "format-wifi": "َ°¤¨ {essid}",
    "format-ethernet": "َ°ˆ€ {ipaddr}",
    "format-disconnected": "َ°¤­ offline",
    "tooltip-format-wifi": "{essid}  {signalStrength}%\n{ipaddr}",
    "tooltip-format-ethernet": "{ifname}\n{ipaddr}"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں muted",
    "format-icons": {
      "default": [
        "َ°•؟",
        "َ°–€",
        "َ°•¾"
      ]
    },
    "on-click": "pavucontrol",
    "tooltip-format": "{volume}% â€” {desc}"
  },
  "tray": {
    "spacing": 8,
    "icon-size": 16
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "َ°‚ڑ",
      "none": "َ°‚œ",
      "dnd-notification": "َ°‚›",
      "dnd-none": "َ°‚›"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "custom/power": {
    "format": "",
    "tooltip": false,
    "on-click": "wlogout"
  }
}
