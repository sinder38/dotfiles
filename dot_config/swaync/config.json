{
    "$schema": "/etc/xdg/swaync/configSchema.json",
    "timeout": 5,
    "timeout-low": 3,
    "timeout-critical": 0,
    "notification-window-width": 400,
    "control-center-width": 400,
    "control-center-height": 600,
    "fit-to-screen": false,
    "positionX": "right",
    "positionY": "top",
    "layer": "overlay",
    "control-center-layer": "top",
    "hide-on-clear": false,
    "hide-on-action": true,
    "widgets": [
        "title",
        "dnd",
        "notifications"
    ],
    "widget-config": {
        "title": {
            "text": "Notifications",
            "clear-all-button": true,
            "button-text": "Clear All"
        },
        "dnd": {
            "text": "Do Not Disturb"
        }
    }
}
