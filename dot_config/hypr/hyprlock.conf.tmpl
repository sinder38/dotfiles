background {
    monitor =
    path = {{ .chezmoi.homeDir }}/.local/share/lockscreen/bg.png
    blur_passes = 0
    brightness = 0.8
}

label {
    monitor =
    text = cmd[update:1000] echo "<b>$(date +"%H:%M")</b>"
    color = rgba(255, 255, 255, 1.0)
    font_size = 80
    font_family = JetBrainsMono Nerd Font
    shadow_passes = 2
    shadow_size = 4
    position = 0, 200
    halign = center
    valign = center
}

label {
    monitor =
    text = cmd[update:60000] echo "$(date +"%A, %B %d")"
    color = rgba(255, 255, 255, 0.8)
    font_size = 22
    font_family = JetBrainsMono Nerd Font
    shadow_passes = 2
    shadow_size = 3
    position = 0, 120
    halign = center
    valign = center
}

input-field {
    monitor =
    size = 280, 52
    outline_thickness = 2
    dots_size = 0.25
    dots_spacing = 0.15
    dots_center = true
    outer_color = rgb(3584e4)
    inner_color = rgba(30, 30, 30, 0.8)
    font_color = rgb(255, 255, 255)
    fade_on_empty = true
    placeholder_text = <i>Password</i>
    rounding = 6
    check_color = rgb(3584e4)
    fail_color = rgb(ff5555)
    fail_text = <i>Wrong password</i>
    capslock_color = rgb(ffb86c)
    position = 0, 0
    halign = center
    valign = center
}
