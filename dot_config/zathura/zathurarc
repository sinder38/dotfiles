# Recolor mode settings (inverts colors for dark theme)
set recolor true
set recolor-darkcolor "#dcdccc"  # text color
set recolor-lightcolor "#1f1f1f" # background color

# Alternative: softer colors
# set recolor-darkcolor "#c5c8c6"
# set recolor-lightcolor "#1d1f21"

# UI colors (optional but recommended)
set notification-error-bg       "#1f1f1f"
set notification-error-fg       "#fb4934"
set notification-warning-bg     "#1f1f1f"
set notification-warning-fg     "#fabd2f"
set notification-bg             "#1f1f1f"
set notification-fg             "#b8bb26"

set completion-bg               "#1f1f1f"
set completion-fg               "#dcdccc"
set completion-group-bg         "#1f1f1f"
set completion-group-fg         "#8ec07c"
set completion-highlight-bg     "#458588"
set completion-highlight-fg     "#1f1f1f"

set index-bg                    "#1f1f1f"
set index-fg                    "#dcdccc"
set index-active-bg             "#458588"
set index-active-fg             "#1f1f1f"

set inputbar-bg                 "#1f1f1f"
set inputbar-fg                 "#dcdccc"
set statusbar-bg                "#1f1f1f"
set statusbar-fg                "#dcdccc"

set highlight-color             "#fabd2f"
set highlight-active-color      "#fe8019"

set default-bg                  "#1f1f1f"
set default-fg                  "#dcdccc"
