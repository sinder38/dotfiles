// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "disable_ai": false,
  "ssh_connections": [
    {
      "host": "hetzner-dev",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/sinder"
          ],
        },
        {
          "paths": [
            "/home/sinder/Projects/OpenSource/CatCAPTCHA"
          ],
        },
        {
          "paths": [
            "/home/sinder/Projects/OpenSource/sea-orm/"
          ],
        },
        {
          "paths": [
            "/home/sinder/Projects/OpenSource/zed"
          ],
        },
      ],
      "nickname": "dev-server",
      "port_forwards": [
        {
          "local_port": 5173,
          "remote_port": 5173,
          // "remote_host": "localhost",
          // "local_host": "localhost"
        },
        {
          // "remote_host": "localhost",
          // "local_host": "localhost",
          "local_port": 3001,
          "remote_port": 3001,
        },
        {
          "local_port": 3000,
          "remote_port": 3000,
        },
        {
          // "local_host": "0.0.0.0",
          "remote_host": "localhost",
          "local_port": 8080,
          "remote_port": 8080,
        },
      ],
    },
  ],
  "command_aliases": {
    "crp": "copyrelativepath",
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "active_pane_modifiers": {
    "border_size": 1,
    "inactive_opacity": 0.9,
  },
  "minimum_contrast_for_highlights": 55.0,
  "expand_excerpt_lines": 30,
  "excerpt_context_lines": 10,
  "completion_menu_scrollbar": "auto",
  "auto_signature_help": false,
  "restore_on_startup": "launchpad",
  "document_symbols": "off",
  "enable_language_server": true,
  "show_wrap_guides": true,
  "inlay_hints": {
    "enabled": false,
    "show_background": true,
  },
  "which_key": {
    "delay_ms": 200,
    "enabled": true,
  },
  "preferred_line_length": 120,
  "soft_wrap": "preferred_line_length",
  "indent_guides": {
    "line_width": 1,
    "background_coloring": "indent_aware",
  },
  "colorize_brackets": true,
  "diagnostics_max_severity": "all",
  // "excerpt_context_lines": 6,
  // "expand_excerpt_lines": 5,
  "bottom_dock_layout": "contained",
  "search": {
    "center_on_match": true,
  },
  "use_smartcase_search": true,
  "context_servers": {
    "postgres-context-server": {
      "enabled": true,
      "settings": {
        "database_url": "postgresql://postgres:welcome@localhost:5432/app_db",
      },
    },
  },
  "prettier": {
    "allowed": false,
  },
  "autoscroll_on_clicks": false,
  "project_panel": {
    "hide_root": true,
    "starts_open": true,
  },
  "git_panel": {
    "tree_view": true,
    "sort_by_path": true,
  },
  "always_treat_brackets_as_autoclosed": false,
  "sticky_scroll": {
    "enabled": true,
  },
  "completions": {
    "lsp": true,
  },
  "show_edit_predictions": true,
  "show_completions_on_input": true,
  "edit_predictions": {
    "mode": "eager",
  },
  "extend_comment_on_newline": false,
  "icon_theme": "Material Icon Theme",
  "when_closing_with_no_tabs": "keep_window_open",
  "buffer_line_height": "standard",
  "terminal": {
    "scrollbar": {
      "show": "auto",
    },
    "toolbar": {
      "breadcrumbs": false,
    },
    "copy_on_select": true,
    "font_size": 14.0,
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "agent": {
    "show_turn_stats": true,
    "notify_when_agent_waiting": "all_screens",
    "single_file_review": true,
    "default_profile": "ask",
    "tool_permissions": {
      "default": "allow",
    },
    "favorite_models": [
      {
        "provider": "anthropic",
        "model": "claude-haiku-4-5-latest",
      },
    ],
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest",
    },
    "default_model": {
      "provider": "anthropic",
      "model": "claude-haiku-4-5-latest",
    },
    "play_sound_when_agent_done": true,
    "message_editor_min_lines": 4,
    "use_modifier_to_send": true,
    "enable_feedback": true,
  },
  "autosave": "off",
  "diagnostics": {
    // Errors are more important. This affects only the default
    "include_warnings": false,
    "inline": {
      "enabled": false,
    },
  },
  "show_whitespaces": "trailing",
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
    "enabled": true,
    "enable_keep_preview_on_code_navigation": true,
    "enable_preview_from_file_finder": true,
  },
  "tabs": {
    "show_close_button": "always",
    "show_diagnostics": "all",
    "file_icons": true,
    "git_status": true,
  },
  "tab_bar": {
    "show": true,
  },
  "title_bar": {
    "show_user_picture": true,
    "show_user_menu": true,
    "show_sign_in": true,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_name": true,
    "show_menus": false,
    "show_branch_icon": true,
  },
  "inline_code_actions": true,
  "relative_line_numbers": "enabled",
  "gutter": {
    "min_line_number_digits": 3,
    "folds": false,
    "runnables": true,
    "breakpoints": false,
    "line_numbers": true,
  },
  "window_decorations": "client",
  "tasks": {
    "prefer_lsp": true,
  },
  "auto_update": true,
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "helix_mode": false,
  "ui_font_family": "JetBrains Mono NL",
  "buffer_font_family": "JetBrains Mono NL",
  "base_keymap": "JetBrains",
  "vim_mode": true,
  "ui_font_size": 14.0,
  "buffer_font_size": 14.0,
  "use_layout_keys": true,
  "theme": "JetBrains Dark",
  // LSP
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classAttributes": [
          "class",
          "className",
          "ngClass",
          "styles"
        ],
      },
    },
    // "rust-analyzer": {
    //   "enable_lsp_tasks": true,
    //   "initialization_options": {
    //     "references": {
    //       "excludeTests": true,
    //     },
    //     // get more cargo-less diagnostics from rust-analyzer,
    //     // which might include false-positives (those can be turned off by their names)
    //     "diagnostics": {
    //       "experimental": {
    //         // "enable": true
    //       },
    //       "styleLints": {
    //         "enable": true,
    //       },
    //     },
    //     // To disable the checking entirely
    //     "checkOnSave": true,
    //     "cargo": {
    //       // // // To check the `lib` target only.
    //       "allTargets": false,
    //       // "true" ocasionally breakes on some creates. Use with caution
    //       "allFeatures": false,
    //     },
    //     // Use `-p` instead of `--workspace` for cargo check
    //     "check": {
    //       "workspace": false,
    //       "allTargets": false,
    //     },
    //     "procMacro": {
    //       "enable": true,
    //     },
    //     // Ocasionally breakes whole error system, not displaying errors. Use with caution
    //     // "check": {
    //     //   "command": "clippy",
    //     //   "workspace": true,
    //     //   "allTargets": true,
    //     // },
    //   },
    // },
  },
  "languages": {
    "Svelte": {
      "prettier": {
        "allowed": true,
      },
    },
    "Rust": {
      "colorize_brackets": true,
      "inlay_hints": {
        "show_background": true,
      },
      "indent_guides": {
        "background_coloring": "indent_aware",
      },
      "show_wrap_guides": true,
      "completions": {
        "words_min_length": 3,
      },
    },
    // Refer https://zed.dev/docs/languages/javascript and https://zed.dev/docs/languages/typescript for more info
    // "TypeScript": {
    //   // Refer https://github.com/jellydn/ts-inlay-hints for how to setup for Neovim and VSCode
    //   "inlay_hints": {
    //     // This is too annoying. Just turn on manually when needed
    //     "enabled": false,
    //     "show_parameter_hints": true,
    //     "show_other_hints": true,
    //     "show_type_hints": true,
    //   },
    // },
    "Python": {
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
      "language_servers": [
        "pyright",
        "ruff"
      ],
    },
    "SQL": {
      "formatter": {
        "external": {
          "command": "sleek",
          "arguments": [
            "--uppercase",
            "true",
            "--trailing-newline",
            "false"
          ],
        },
      },
    },
  },
}
