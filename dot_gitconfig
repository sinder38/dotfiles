    email = smirnov.sinder@gmail.com
	signingkey = 7F826072F552FA3A7AFA3300D83D7F79E6255EF5

[alias]
    recent = for-each-ref --format='%(refname:short) %(committerdate:relative) %(subject)' refs/heads/ --sort=-committerdate
    ed = branch --no-merged main -v
    diff-main = log main..HEAD --oneline
    glog = log --graph --oneline --decorate
[core]
	editor = zeditor --wait
	autocrlf = input

[init]
    defaultBranch = main
[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[push]
	autoSetupRemote = true
[credential]
	helper = store
[commit]
	gpgsign = true
