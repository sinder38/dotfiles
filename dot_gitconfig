[user]
	name = sinder
    email = smirnov.sinder@gmail.com

[alias]
    recent = for-each-ref --format='%(refname:short) %(committerdate:relative) %(subject)' refs/heads/ --sort=-committerdate
    ed = branch --no-merged main -v
    diff-main = log main..HEAD --oneline

[core]
	editor = zeditor --wait
	autocrlf = input

[init]
    defaultBranch = main
[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[push]
	autoSetupRemote = true
[credential]
	helper = store
